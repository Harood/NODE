<%- include('../partials/head', {pageTitle: 'Add Property'}) %>
</head>
<body class="bg-gray-100">
    <%- include('partials/nav') %>
    <h1 class="text-3xl font-bold text-center text-red-800 mb-6 pt-2">Add a New Property</h1>
    <form action="/host/add-property" method="POST" class="max-w-md mx-auto bg-white p-6 rounded-lg shadow-md space-y-4">
        <input type="text" name="title" placeholder="Property Title" required class="w-full p-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-orange-500" />
        <input type="text" name="location" placeholder="Location" required class="w-full p-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-orange-500" />
        <input type="number" name="price" placeholder="Price per night" required class="w-full p-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-orange-500" />
        <input type="text" name="image" placeholder="Image URL" required class="w-full p-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-orange-500" />
        <button type="submit" class="w-full bg-red-500 text-white py-2 px-4 rounded hover:bg-orange-700">Add Property</button>
    </form>
</body>
</html>
