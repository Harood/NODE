<form action="/favourite-list" method="POST" class="inline">
    <input type="hidden" name="propertyId" value="<%= property.id %>">
    <button
        type="submit"
        class="inline-flex items-center justify-center rounded-full border border-red-500 px-4 py-2 text-xs sm:text-sm font-medium text-red-500 bg-white hover:bg-red-50 focus:outline-none focus:ring-2 focus:ring-red-400 focus:ring-offset-1"
    >
        Add to favourites
    </button>
</form>