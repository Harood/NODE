<%- include('../partials/head', {pageTitle: 'Airbnb Home'}) %>
</head>
<body class="min-h-screen bg-slate-100 text-slate-900">
    <%- include('../partials/nav') %>
    <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
        <section class="overflow-hidden rounded-3xl bg-linear-to-r from-rose-600 via-rose-500 to-orange-500 px-6 py-10 text-white shadow-xl sm:px-10">
            <div class="max-w-3xl">
                <p class="text-sm font-semibold uppercase tracking-[0.25em] text-rose-100/90">Airbnb Homes</p>
                <h1 class="mt-3 text-3xl font-bold sm:text-5xl">Discover registered homes in one place.</h1>
                <p class="mt-4 max-w-2xl text-sm leading-6 text-rose-50/90 sm:text-base">
                    Browse available listings, compare prices, and save the homes you like for later.
                </p>
            </div>
        </section>

        <section class="mt-8">
            <div class="mb-5 flex items-center justify-between gap-4">
                <div>
                    <h2 class="text-2xl font-semibold text-slate-900">Showing Registered Homes</h2>
                    <p class="mt-1 text-sm text-slate-500"><%= properties.length %> available listing<%= properties.length === 1 ? '' : 's' %></p>
                </div>
            </div>

            <% if (properties.length === 0) { %>
                <div class="rounded-2xl border border-dashed border-slate-300 bg-white px-6 py-16 text-center shadow-sm">
                    <h3 class="text-xl font-semibold text-slate-800">No homes available yet</h3>
                    <p class="mt-2 text-sm text-slate-500">Once hosts add properties, they will appear here.</p>
                </div>
            <% } else { %>
                <ul class="grid gap-6 sm:grid-cols-2 xl:grid-cols-3">
                    <% properties.forEach(function(property) { %>
                        <li class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm transition duration-200 hover:-translate-y-1 hover:shadow-lg">
                            <div class="relative">
                                <img
                                    class="h-56 w-full object-cover"
                                    src="<%= property.photo || property.image %>"
                                    alt="<%= property.houseName %>"
                                >
                                <div class="absolute left-4 top-4 rounded-full bg-white/95 px-3 py-1 text-xs font-semibold text-rose-600 shadow">
                                    <%= property.location || 'Popular stay' %>
                                </div>
                            </div>

                            <div class="space-y-4 p-5">
                                <div>
                                    <div class="flex items-start justify-between gap-3">
                                        <h3 class="text-lg font-semibold text-slate-900"><%= property.houseName %></h3>
                                        <p class="shrink-0 text-sm font-semibold text-amber-500">⭐ <%= property.rating || 'N/A' %></p>
                                    </div>
                                    <p class="mt-1 text-sm text-slate-500"><%= property.location %></p>
                                </div>

                                <div class="flex items-center justify-between">
                                    <p class="text-lg font-bold text-rose-600">$<%= property.price %><span class="text-sm font-medium text-slate-500">/night</span></p>
                                    <p class="text-xs font-medium uppercase tracking-wider text-slate-400">Verified listing</p>
                                </div>

                                <div class="flex gap-3">
                                    <a href="/homes/<%= property._id %>" class="inline-flex flex-1 items-center justify-center rounded-lg bg-slate-900 px-4 py-2 text-sm font-semibold text-white transition hover:bg-slate-800">
                                        Details
                                    </a>
                                    <form action="/favourite-list" method="POST" class="flex-1">
                                        <input type="hidden" name="propertyId" value="<%= property._id %>">
                                        <button type="submit" class="inline-flex w-full items-center justify-center gap-2 rounded-lg border border-rose-200 bg-rose-50 px-4 py-2 text-sm font-semibold text-rose-600 transition hover:bg-rose-100">
                                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" stroke="none">
                                                <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.53L12 21.35z" />
                                            </svg>
                                            Favourite
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </li>
                    <% }); %>
                </ul>
            <% } %>
        </section>
    </main>
</body>
</html>