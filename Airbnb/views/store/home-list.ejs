<%- include('../partials/head', {pageTitle: 'Airbnb Home'}) %>
</head>
<body>
    <%- include('../partials/nav') %>

    <main class="min-h-screen bg-gray-50 py-10">
        <section class="max-w-6xl mx-auto px-4">
            <header class="mb-10 text-center">
                <p class="text-sm font-semibold tracking-wide text-red-500 uppercase">
                    Available stays
                </p>
                <h1 class="mt-2 text-3xl font-bold tracking-tight text-gray-900">
                    Showing registered homes
                </h1>
                <p class="mt-2 text-sm text-gray-500">
                    Browse all properties and open any card for full details.
                </p>
            </header>

            <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                <% properties.forEach(function(property) { %>
                    <li class="group bg-white rounded-2xl shadow-sm overflow-hidden border border-gray-100 hover:shadow-xl transition-shadow duration-200 flex flex-col">
                        <div class="relative h-52">
                            <img
                                class="h-full w-full object-cover"
                                src="<%= property.image %>"
                                alt="Photo of <%= property.title %>"
                            >
                            <div class="absolute top-3 left-3 rounded-full bg-black/60 px-3 py-1 text-xs font-semibold text-white">
                                $<%= property.price %> / night
                            </div>
                        </div>

                        <div class="flex-1 p-4 flex flex-col justify-between">
                            <div>
                                <h2 class="text-lg font-semibold text-gray-900 group-hover:text-red-500 transition-colors">
                                    <%= property.title %>
                                </h2>
                                <p class="mt-1 text-sm text-gray-500">
                                    <%= property.location %>
                                </p>
                            </div>

                            <div class="mt-4 flex flex-col gap-2">
                                <div class="flex items-center justify-between text-xs text-gray-500">
                                    <span>Listing #<span class="font-semibold text-gray-700"><%= property.id %></span></span>
                                </div>
                                <div class="flex flex-wrap gap-2 justify-between items-center">
                                    <a
                                        href="/homes/<%= property.id %>"
                                        class="inline-flex items-center justify-center rounded-full border border-gray-200 px-4 py-2 text-xs sm:text-sm font-medium text-gray-700 hover:bg-gray-50"
                                    >
                                        View details
                                    </a>
                                    <%- include('../partials/favourite', { property: property }) %>
                                    <button
                                        class="inline-flex items-center justify-center rounded-full bg-red-500 px-4 py-2 text-xs sm:text-sm font-semibold text-white shadow-sm hover:bg-red-600 focus:outline-none focus:ring-2 focus:ring-red-400 focus:ring-offset-1"
                                    >
                                        Book now
                                    </button>
                                </div>
                            </div>
                        </div>
                    </li>
                <% }); %>
            </ul>
        </section>
    </main>
</body>
</html>