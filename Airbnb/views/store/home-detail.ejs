<%- include('../partials/head', {pageTitle: 'Airbnb Home'}) %>
</head>
<body>
    <%- include('../partials/nav') %>
    <!-- Welcome Section -->
    <p class="text-red-500 text-center text-2xl font-bold">Here is Home detail</p>
    <div class="flex items-center justify-center">
        <img class="rounded object-cover" src="<%= property.image %>" alt="Property Image">
                    <div class="flex items-center justify-between mt-2">
                        <div>
                            <h2 class="font-semibold text-xl pl-2"><%= property.title %></h2>
                            <p class="text-gray-500 pl-2"><%= property.location %></p>
                            <p class="text-red-500 font-bold pl-2">$<%= property.price%>/night</p></div>
                        <div class="mr-2 mt-10">
                            <a href="/homes/<%= property.id %>" class="bg-blue-500 text-white py-1 px-4 rounded hover:bg-blue-600">Details</a>
                            <button class="bg-red-500 text-white py-1 px-4 rounded hover:bg-red-600 ml-2 ">Book Now</button>
                        </div> 
                    </div>   
    </div>
</body>
</html>