<%- include('../partials/head', {pageTitle: property.houseName}) %>
</head>
<body>
    <%- include('../partials/nav') %>

    <!-- Property Detail Section -->
    <div class="max-w-4xl mx-auto px-4 py-10">
        <!-- Hero Image -->
        <div class="rounded-2xl overflow-hidden shadow-lg">
            <img class="w-full h-[420px] object-cover" src="<%= property.image %>" alt="<%= property.houseName %>">
        </div>

        <!-- Property Info -->
        <div class="mt-8 flex flex-col md:flex-row md:items-start md:justify-between gap-6">
            <!-- Left: Details -->
            <div class="flex-1">
                <h1 class="text-3xl font-bold text-gray-900"><%= property.houseName %></h1>
                <div class="flex items-center gap-2 mt-2 text-gray-500">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.828 0L6.343 16.657a8 8 0 1111.314 0z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                    <span class="text-lg"><%= property.location %></span>
                </div>
                <div class="flex items-center gap-1 mt-2">
                    <span class="text-yellow-500 text-lg">⭐</span>
                    <span class="text-lg font-semibold text-gray-700"><%= property.rating || 'N/A' %></span>
                    <span class="text-sm text-gray-400">/5</span>
                </div>
                <div class="mt-4 border-t pt-4">
                    <p class="text-gray-600 text-base leading-relaxed">
                        Experience a wonderful stay at <strong><%= property.houseName %></strong> in the heart of <%= property.location %>.
                        This property offers comfort, style, and an unforgettable experience.
                    </p>
                </div>
            </div>

            <!-- Right: Price Card -->
            <div class="bg-white border border-gray-200 rounded-xl shadow-md p-6 w-full md:w-72 flex-shrink-0">
                <div class="text-center">
                    <p class="text-sm text-gray-500 uppercase tracking-wide">Price per night</p>
                    <p class="text-4xl font-extrabold text-red-500 mt-1">$<%= property.price %></p>
                </div>
                <form action="/favourite-list" method="POST" class="mt-6">
                    <input type="hidden" name="propertyId" value="<%= property._id %>">
                    <button type="submit" class="w-full flex items-center justify-center gap-2 bg-red-500 hover:bg-red-600 text-white font-semibold py-3 px-4 rounded-lg transition-colors duration-200">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                        </svg>
                        Add to Favourites
                    </button>
                </form>
                <a href="/" class="block text-center mt-3 text-sm text-gray-500 hover:text-gray-700 underline">Back to all properties</a>
            </div>
        </div>
    </div>
</body>
</html>